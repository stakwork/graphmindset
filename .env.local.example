# API URL for the boltwall/backend service
# Leave empty to auto-detect from hostname (swarm) or default to bitcoin.sphinx.chat
NEXT_PUBLIC_API_URL=

# Mock mode for local development (skip real API calls)
NEXT_PUBLIC_USE_MOCKS=true

# Dev-only overlays in the graph view: cluster glyph picker (Concentric / Hex
# / Petal / Constellation / Star) + world-anchored debug markers for the
# camera-positioning bug. Set to 1 to enable; production builds should leave
# this unset so no debug UI ships.
NEXT_PUBLIC_DEBUG_MARKERS=
